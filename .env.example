# Root Docker Compose local development template.
# Copy to .env before running docker compose.
# These are local placeholders only. Do not use them in production.

APP_ENV=development
ENVIRONMENT=development
APP_NAME=World Cup Intelligence Platform
DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_USER=wcip
POSTGRES_PASSWORD=replace-with-generated-local-postgres-password
POSTGRES_DB=wcip
DATABASE_URL=postgresql+psycopg2://wcip:replace-with-generated-local-postgres-password@db:5432/wcip

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

SECRET_KEY=replace-with-generated-local-secret
JWT_SECRET_KEY=replace-with-generated-local-jwt-secret
JWT_REFRESH_SECRET_KEY=replace-with-generated-local-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://world-cup-intelligence-platform.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://world-cup-intelligence-platform.vercel.app
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://world-cup-intelligence-platform.vercel.app
CORS_ORIGIN_REGEX=https://world-cup-intelligence-platform(?:-[a-z0-9-]+)?\.vercel\.app
BACKEND_CORS_ORIGIN_REGEX=https://world-cup-intelligence-platform(?:-[a-z0-9-]+)?\.vercel\.app

FOOTBALL_DATA_API_KEY=replace-with-your-api-key
API_FOOTBALL_KEY=replace-with-your-api-key
FIFA_RANKING_SOURCE_URL=https://inside.fifa.com/fifa-world-ranking/men
ELO_RATING_SOURCE_URL=https://www.eloratings.net/2026_World_Cup
ELO_RATING_TSV_URL=https://www.eloratings.net/World.tsv

LOG_LEVEL=INFO

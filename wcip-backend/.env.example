# Backend local development template.
# Copy to .env or run: python scripts/generate_local_env.py
# Values here are placeholders only. Never commit a real .env file.

APP_ENV=development
ENVIRONMENT=development
APP_NAME=World Cup Intelligence Platform
PROJECT_NAME=World Cup Intelligence Platform
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=sqlite:///./wcip.db
POSTGRES_USER=wcip
POSTGRES_PASSWORD=replace-with-generated-local-postgres-password
POSTGRES_DB=wcip
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=replace-with-generated-local-secret
JWT_REFRESH_SECRET_KEY=replace-with-generated-local-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

FOOTBALL_DATA_API_KEY=replace-with-your-api-key
API_FOOTBALL_KEY=replace-with-your-api-key
FIFA_RANKING_SOURCE_URL=https://inside.fifa.com/fifa-world-ranking/men
ELO_RATING_SOURCE_URL=https://www.eloratings.net/2026_World_Cup
ELO_RATING_TSV_URL=https://www.eloratings.net/World.tsv

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CACHE_TTL_SECONDS=300

RATE_LIMIT_PER_MINUTE=120
MAX_MONTE_CARLO_RUNS=50000
SYNC_SIM_RUN_THRESHOLD=2000

ML_MODELS_DIR=models
ML_FEATURE_VERSION=v2
ETL_AUTO_RUN_ON_STARTUP=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

LOG_LEVEL=INFO

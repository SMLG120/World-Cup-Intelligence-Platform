# Copy to .env and fill in. Defaults run locally with SQLite + in-memory cache.

ENVIRONMENT=development
DEBUG=true

# --- security (REQUIRED in production) ---
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- database ---
# Local default is SQLite. For production use PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://wcip:wcip@db:5432/wcip
DATABASE_URL=sqlite:///./wcip.db

# --- redis / celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CACHE_TTL_SECONDS=300

# --- CORS (comma-separated) ---
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- rate limiting ---
RATE_LIMIT_PER_MINUTE=120

# --- simulation guardrails ---
MAX_MONTE_CARLO_RUNS=50000
SYNC_SIM_RUN_THRESHOLD=2000

# --- OAuth (optional, used by NextAuth on the frontend) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- data sources (Phase 2) ---
# Free API key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- ML / ETL ---
ML_MODELS_DIR=models
ML_FEATURE_VERSION=v1
# Set true to auto-run ETL on startup (useful for production deploys)
ETL_AUTO_RUN_ON_STARTUP=false

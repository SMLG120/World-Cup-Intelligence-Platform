# Frontend local development template.
# Copy to .env.local or run from backend: python scripts/generate_local_env.py
# Values here are public browser configuration only.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE=/backend/api/v1
NEXT_PUBLIC_APP_NAME=World Cup Intelligence Platform
NEXT_PUBLIC_ENABLE_ML=true
NEXT_PUBLIC_ENABLE_SCENARIOS=true
NEXT_PUBLIC_ENABLE_EXPLAINABILITY=true

# Server-side internal URL for the Next.js rewrite proxy.
BACKEND_INTERNAL_URL=http://localhost:8000
